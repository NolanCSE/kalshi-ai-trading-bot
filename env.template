# Kalshi API Configuration
# Get your API key from: https://trading.kalshi.com/settings/api
KALSHI_API_KEY=your_kalshi_api_key_here

# xAI API Configuration
# Get your API key from: https://console.x.ai/
XAI_API_KEY=your_xai_api_key_here

# OpenRouter API Configuration (multi-model ensemble)
# Get your API key from: https://openrouter.ai/keys
OPENROUTER_API_KEY=your_openrouter_api_key_here

# NewsAPI Configuration (primary live news source)
# Get your API key from: https://newsapi.org/register
NEWSAPI_KEY=your_newsapi_key_here

# Brave Search API Configuration (fallback live news source)
# Get your API key from: https://brave.com/search/api/
BRAVE_API_KEY=your_brave_api_key_here

# GCP Tunnel Configuration (used by scripts/tunnel_mcp.sh)
# Get your GCP project ID from: gcloud config get-value project
GCP_PROJECT=your_gcp_project_id_here

# VM instance name in GCP (e.g., openclaw-vm)
VM_INSTANCE=your_vm_instance_name_here

# GCP zone (e.g., us-central1-a)
ZONE=us-central1-a

# MCP server port (default: 8765)
MCP_PORT=8765

# OpenAI API Configuration (fallback)
# Get your API key from: https://platform.openai.com/api-keys
OPENAI_API_KEY=your_openai_api_key_here

# Trading Configuration
# Set to 'true' for live trading, 'false' for paper trading
LIVE_TRADING_ENABLED=false

# Logging Configuration
LOG_LEVEL=INFO
ENABLE_FILE_LOGGING=true
ENABLE_CONSOLE_LOGGING=true

# Database Configuration
DATABASE_URL=sqlite:///trading_system.db

# Performance Monitoring
ENABLE_PERFORMANCE_MONITORING=true
PERFORMANCE_LOG_INTERVAL_MINUTES=15
