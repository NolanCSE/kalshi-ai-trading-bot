# Force LF line endings in the working tree for all files git considers text.
# This prevents Windows tools from converting shell scripts to CRLF, which
# breaks the #!/usr/bin/env bash shebang under WSL.

# Default: all text files get LF on checkout
* text=auto eol=lf

# Shell scripts must always be LF — never CRLF
*.sh        text eol=lf

# Python files
*.py        text eol=lf

# Config / data files
*.yaml      text eol=lf
*.yml       text eol=lf
*.toml      text eol=lf
*.json      text eol=lf
*.md        text eol=lf
*.txt       text eol=lf
*.env       text eol=lf
*.service   text eol=lf
*.sql       text eol=lf

# Binary files — never touch line endings
*.png       binary
*.jpg       binary
*.jpeg      binary
*.gif       binary
*.ico       binary
*.pdf       binary
*.db        binary
*.sqlite    binary
*.sqlite3   binary
*.pkl       binary
*.pyc       binary
